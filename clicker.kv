#:import from_hex kivy.utils.get_color_from_hex
#:import colormap kivy.utils.colormap

#:set main_color "#F3AF12"
#:set main_color_dark "#F37C12"

<Widget>:
    font_name: 'assets/fonts/lemon-regular.ttf'


# Спільний стиль кнопок меню
<ButtonMenu@Button>:
    font_size: "20sp"
    size_hint: 1, 0.15
    background_normal: ''
    background_color: from_hex(main_color)
    color: 0, 0, 0, 1  # чорний текст
    on_press:
        self.background_color = from_hex(main_color_dark)
    on_release:
        self.background_color = from_hex(main_color)

<Fish>:
    allow_stretch: True
    keep_ratio: True
    canvas.before:
        # Запам'ятати поточний стан:
        PushMatrix 
        Rotate:
            angle: root.angle      #Обертати на визначений кут
            origin: self.center    #Обертати навколо центру зображення
    canvas.after:
        # Повернути стан назад:
        PopMatrix                  

<MenuScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "20dp"

        canvas.before:
            #Color:
            #    rgba: colormap['blue']
            #Rectangle:
            #    pos: self.pos
            #    size: self.size
            Rectangle:            # Вставлення зображення тла
                source: "assets/images/background.jpg"
                pos: self.pos
                size: self.size
            Color:                # Затемнення тла, щоб краще читалося все інше
                rgba: 0, 0, 0, 0.35
            Rectangle:
                pos: self.pos
                size: self.size

        Image:
            source: "assets/images/click.png"
            size_hint: 1, 0.5

        Label:
            #text: "Main Menu"
            text: "SUMMER\nCLICKER"
            font_size: "40sp"
            size_hint: 1, 0.2

        ButtonMenu:
            text: "PLAY"
            on_press: root.go_game()

        ButtonMenu:
            text: "SETTINGS"
            on_press: root.go_settings()

        ButtonMenu:
            text: "EXIT"
            on_press: root.exit_app()


<GameScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "20dp"

        # Зміна тла на екрані гри
        canvas.before: 
            Rectangle:
                source: "assets/images/background_game.jpg"
                pos: self.pos
                size: self.size
            Color:
                rgba: 0, 0, 0, 0.2
            Rectangle:
                pos: self.pos
                size: self.size
        
        Label:
            text: "Level " + str(root.level)
            font_size: "28sp"
            color: 0, 0, 1, 1        # Зміна кольору тексту
            size_hint_y: None
            height: "40dp"
            outline_width: 5         # Контур навколо літер (чорний)
            outline_color: 0, 0, 0, 0.15

        Label:
            text: "Score: " + str(root.score)
            font_size: "32sp"
            color: 0, 0, 1, 1 # Зміна кольору тексту
            size_hint_y: None
            height: "50dp"

        FloatLayout:

            Fish:
                id: fish
                #size_hint: 0.4, 0.2
                #pos_hint: {"center_x": 0.5, "center_y": 0.6}
                size_hint: None, None

            Label:
                id: level_complete
                halign: "center"
                valign: "middle"
                text_size: self.size
                text: "LEVEL\nCOMPLETE!"
                font_size: "40sp"
                color: 0, 1, 0, 1
                opacity: 0
                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                outline_width: 3
                outline_color: 0.17, 0.74, 0.33, 0.1 # Контур іншого кольору

        ButtonMenu:
            text: "Back to Menu"
            size_hint_y: None
            height: "60dp"
            on_press: root.go_menu()


<SettingsScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "20dp"

        Label:
            text: "Settings"
            font_size: "40sp"

        ButtonMenu:
            text: "Back to Menu"
            on_press: root.go_menu()

